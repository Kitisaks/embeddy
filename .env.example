# Required
EMBED_API_TOKEN=your-secret-token

# Inference device: cpu (default), mps (Apple Silicon), or cuda
EMBED_DEVICE=cpu

# Inference concurrency / batching
MAX_BATCH_SIZE=32
MAX_CONCURRENT_REQUESTS=2

# CPU thread limits (set before process start; OpenMP/MKL read these at library init)
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
TORCH_NUM_THREADS=2
TORCH_INTEROP_THREADS=1

# Optional: dynamic int8 quantization (~1.5-2x CPU throughput, slight quality trade-off)
ENABLE_QUANTIZATION=false

# Hugging Face tokenizers: avoid thread oversubscription with torch
TOKENIZERS_PARALLELISM=false
